services:
  - type: web
    name: fin-ems-backend
    env: node
    buildCommand: npm install
    startCommand: node portfolio/ems-store/ems/server.js
    rootDir: portfolio/ems-store/ems
    plan: free
    envVars:
      - key: NODE_ENV
        value: production
      - key: PORT
        value: 10000
    healthCheckPath: /health
    autoDeploy: true
    
  - type: web
    name: fin-ems-frontend
    env: static
    buildCommand: npm install && npm run build
    staticPublishPath: ./dist
    rootDir: portfolio/ems-store/ems-frontend
    plan: free
    envVars:
      - key: NODE_ENV
        value: production
    autoDeploy: true

  - type: web
    name: portfolio-frontend
    env: static
    buildCommand: npm install && npm run build
    staticPublishPath: ./dist
    rootDir: portfolio/portfolio-frontend
    plan: free
    autoDeploy: true